<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Service"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1D9E75"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Service Name"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etServiceName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. Fan Repair, Pipe Fixing"
            android:padding="14dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/input_background"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Price (₹)"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 200"
            android:inputType="numberDecimal"
            android:padding="14dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/input_background"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Price Type"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="6dp"/>

        <RadioGroup
            android:id="@+id/rgPriceType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rbFixed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fixed Price"
                android:checked="true"
                android:textColor="#333333"
                android:layout_marginEnd="24dp"/>

            <RadioButton
                android:id="@+id/rbStartingAt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Starting At"
                android:textColor="#333333"/>

        </RadioGroup>

        <Button
            android:id="@+id/btnAddService"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Service"
            android:backgroundTint="#1D9E75"
            android:textColor="#FFFFFF"
            android:padding="14dp"/>

    </LinearLayout>
</ScrollView>