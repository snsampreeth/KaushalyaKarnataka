<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1D9E75"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Assistant"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Powered by Gemini AI"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Find right worker -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Find the Right Worker"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#222222"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Describe your problem and get advice"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etProblem"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. My fan is not working"
                        android:padding="12dp"
                        android:minLines="2"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/input_background"/>

                    <Button
                        android:id="@+id/btnFindWorker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Get Advice"
                        android:backgroundTint="#1D9E75"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvWorkerAdvice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Price checker -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Price Checker"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#222222"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Check if the price is fair before hiring"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etServiceCheck"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. Electrician fan repair ₹300"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/input_background"/>

                    <Button
                        android:id="@+id/btnCheckPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Check Price"
                        android:backgroundTint="#1D9E75"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvPriceCheck"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Questions to ask -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Questions to Ask Worker"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#222222"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Get smart questions before hiring"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etWorkerType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. Plumber, Electrician"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/input_background"/>

                    <Button
                        android:id="@+id/btnGetQuestions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Get Questions"
                        android:backgroundTint="#1D9E75"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvQuestions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>